{
  "name": "spond-assignment",
  "version": "1.0.0",
  "scripts": {
    "backend:run": "cd backend && air",
    "backend:build": "cd backend && go build -o bin/api ./cmd/api",
    "backend:test": "cd backend && go test ./...",
    "backend:format": "cd backend && gofmt -s -w .",
    "backend:format-check": "cd backend && gofmt -l .",
    "backend:lint": "cd backend && golangci-lint run",
    "backend:lint-fix": "cd backend && golangci-lint run --fix",
    "frontend:install": "cd frontend && npm install",
    "frontend:run": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:test": "cd frontend && npm run test",
    "frontend:testw": "cd frontend && npm run test:watch",
    "frontend:lint": "cd frontend && npm run lint",
    "frontend:lint-fix": "cd frontend && npm run lint:fix",
    "frontend:format": "cd frontend && npm run format",
    "frontend:format-check": "cd frontend && npm run format:check",
    "frontend:check": "cd frontend && npm run check",
    "generate:types": "cd backend && tygo generate",
    "db:migrate": "psql postgres://postgres:postgres@localhost:5432/spond?sslmode=disable -f backend/migrations/001_init.sql",
    "db:clear": "psql postgres://postgres:postgres@localhost:5432/spond?sslmode=disable -c \"DROP TABLE IF EXISTS registrations;\"",
    "db:upd": "docker compose -f compose.dev.yml up -d",
    "db:up": "docker compose -f compose.dev.yml up",
    "db:downd": "docker compose -f compose.dev.yml down",
    "local-prod:up": "docker compose -f compose.local-prod.yml up --build",
    "local-prod:upd": "docker compose -f compose.local-prod.yml up --build -d",
    "local-prod:downd": "docker compose -f compose.local-prod.yml down -d",
    "e2e:up": "docker compose -f compose.e2e.yml up --build",
    "e2e:upd": "docker compose -f compose.e2e.yml up --build -d",
    "e2e:downd": "docker compose -f compose.e2e.yml down -d",
    "e2e:test": "cd frontend && npx playwright test --workers=1",
    "dev": "mprocs"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}